[core]
	autocrlf = true
	symlinks = true
[filter "lfs"]
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
[lfs]
	batch = true
[user]
	name = Trịnh Ngọc Các
	email = cactrinh5@gmail.com
[alias]
    ai = add -i
    br = branch
    com = commit
    ll = log --graph --oneline
    rbi = rebase -i
    st = status
    unstage = restore --staged
[http]
	sslcainfo = E:/Git/mingw64/etc/ssl/certs/ca-bundle.crt
